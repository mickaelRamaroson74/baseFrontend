{
  "name": "base-frontend",
  "private": true,
  "workspaces": [
    "apps/*",
    "libs/*"
  ],
  "scripts": {
    "storybook": "npm run storybook --workspace=libs/ui",
    "build-storybook": "npm run build-storybook --workspace=libs/ui",
    "prepare": "husky install",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx --ignore-path .eslintignore",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --ignore-path .eslintignore --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "volta": {
    "node": "22.22.2"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.10.0",
    "@typescript-eslint/parser": "^6.10.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.35",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-jsx-a11y": "^6.8.0",
    "eslint-plugin-prettier": "^5.1.4",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "husky": "^9.0.0",
    "lint-staged": "^14.0.0",
    "prettier": "^3.0.0"
  }
}
